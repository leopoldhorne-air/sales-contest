# Upstash Redis — copy from Vercel dashboard > Integrations > Upstash Redis > .env.local
# Or from upstash.com > your database > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Zapier webhook secret — any random string, must match what you set in Zapier's custom header
WEBHOOK_SECRET=your-secret-here
